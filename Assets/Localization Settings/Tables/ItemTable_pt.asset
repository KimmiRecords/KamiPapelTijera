  m_TableData:
  - m_Id: 7627980800
    m_Localized: "\"Vamos l\xE1, querida, vai em frente, estou com fome!\""
    m_Metadata:
      m_Items: []
  - m_Id: 26959527936
    m_Localized: "Vov\xF3 Ameya"
    m_Metadata:
      m_Items: []
  - m_Id: 161185644544
    m_Localized: "Esses fungos raros crescem na cabe\xE7a das galinhas."
    m_Metadata:
      m_Items: []
  - m_Id: 295034273792
    m_Localized: Fungo
    m_Metadata:
      m_Items: []
  - m_Id: 359928545280
    m_Localized: "Dalia usa essas flores para suas po\xE7\xF5es malucas."
    m_Metadata:
      m_Items: []
  - m_Id: 375640408064
    m_Localized: Flor de klematis
    m_Metadata:
      m_Items: []
  - m_Id: 488521711616
    m_Localized: "Com essas botas, voc\xEA pode pressionar SHIFT para ir mais r\xE1pido."
    m_Metadata:
      m_Items: []
  - m_Id: 503566680064
    m_Localized: "Botas de leitura r\xE1pida"
    m_Metadata:
      m_Items: []
  - m_Id: 620076056576
    m_Localized: "Se voc\xEA for atravessar trechos alagados, com essas botas pode
      esquecer a ideia de se molhar!"
    m_Metadata:
      m_Items: []
  - m_Id: 666192429056
    m_Localized: Botas
    m_Metadata:
      m_Items: []
  - m_Id: 799055396864
    m_Localized: "Retalhos de papel. Podem ser usados \u200B\u200Bpara fazer origami."
    m_Metadata:
      m_Items: []
  - m_Id: 809390161920
    m_Localized: Papel
    m_Metadata:
      m_Items: []
  - m_Id: 893766975488
    m_Localized: "Clique para cortar!\n\nEsta tesoura pertencia \xE0 sua m\xE3e."
    m_Metadata:
      m_Items: []
  - m_Id: 906815455232
    m_Localized: Tesoura
    m_Metadata:
      m_Items: []
  - m_Id: 960443826176
    m_Localized: Essas enormes tesouras forjadas por El Chino podem cortar pedras
      e rochas.
    m_Metadata:
      m_Items: []
  - m_Id: 989661347840
    m_Localized: Tesoura de Ouro
