  m_SharedData: {fileID: 11400000, guid: 9cc37759799fc3247b25e758e71d0e54, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 39571800064
    m_Localized: "Voc\xEA deixou a vov\xF3 em casa!"
    m_Metadata:
      m_Items: []
  - m_Id: 216298799104
    m_Localized: "Pressione E para virar a p\xE1gina."
    m_Metadata:
      m_Items: []
  - m_Id: 289451655168
    m_Localized: "Pressione E para retornar \xE0 p\xE1gina anterior."
    m_Metadata:
      m_Items: []
  - m_Id: 489079554048
    m_Localized: "A galinha est\xE1 tentando te evitar!"
    m_Metadata:
      m_Items: []
  - m_Id: 2542224916480
    m_Localized: Pressione E para pegar a tesoura.
    m_Metadata:
      m_Items: []
  - m_Id: 2623854460928
    m_Localized: Pressione E para conversar
    m_Metadata:
      m_Items: []
  - m_Id: 2776837505024
    m_Localized: Mantenha pressionada a tecla E para iniciar o origami.
    m_Metadata:
      m_Items: []
  - m_Id: 2880432619520
    m_Localized: Pressione E para puxar a aba.
    m_Metadata:
      m_Items: []
  - m_Id: 2974607327232
    m_Localized: Use Clique para cortar
    m_Metadata:
      m_Items: []
  - m_Id: 3105733853184
    m_Localized: "Cuidado com a \xE1gua! Use o suporte de origami para dobrar uma
      ponte."
    m_Metadata:
      m_Items: []
  - m_Id: 3175216693248
    m_Localized: "Cuidado com a \xE1gua! Voc\xEA \xE9 feito de papel e pode se estragar
      :c Pule usando a BARRA DE ESPA\xC7O."
    m_Metadata:
      m_Items: []
  - m_Id: 3266073706496
    m_Localized: Pressione U para ver as tarefas pendentes.
    m_Metadata:
      m_Items: []
  - m_Id: 3331534209024
    m_Localized: "N\xE3o se esque\xE7a: origami custa papel."
    m_Metadata:
      m_Items: []
  - m_Id: 3418658291712
    m_Localized: "Cuidado com as \xE1rvores rochosas! Elas aguentam a tesoura de
      poda... mas n\xE3o uma \xE1rvore na cabe\xE7a."
    m_Metadata:
      m_Items: []
  - m_Id: 3511264329728
    m_Localized: "Pedra vence tesoura, mas n\xE3o uma \xE1rvore de papel."
    m_Metadata:
      m_Items: []
  - m_Id: 4099364470784
    m_Localized: "Use o bot\xE3o central para alternar entre as c\xE2meras."
    m_Metadata:
      m_Items: []
  - m_Id: 4182503964672
    m_Localized: "Voc\xEA acordou o Rocoso!"
    m_Metadata:
      m_Items: []
  - m_Id: 5736808169472
    m_Localized: "Arraste a seta verde at\xE9 o alvo e solte. N\xE3o se desvie do
      caminho!"
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
