  m_TableData:
  - m_Id: 86589947904
    m_Localized: Leve 100 folhas de papel para Chino para que ele possa acender o
      forno e comprar uma tesoura melhor.
    m_Metadata:
      m_Items: []
  - m_Id: 182454960128
    m_Localized: "Corte 3 flores roxas e leve-as para Dalia para que ela possa preparar
      suas po\xE7\xF5es energizantes."
    m_Metadata:
      m_Items: []
  - m_Id: 205943062528
    m_Localized: Dalia I
    m_Metadata:
      m_Items: []
  - m_Id: 70215385088
    m_Localized: "A av\xF3 saiu para passear e se perdeu na floresta."
    m_Metadata:
      m_Items: []
  - m_Id: 12325601280
    m_Localized: "Tragam a vov\xF3 de volta!"
    m_Metadata:
      m_Items: []
  - m_Id: 148044890112
    m_Localized: "Chin\xEAs I"
    m_Metadata:
      m_Items: []
  - m_Id: 269067337728
    m_Localized: "As galinhas do Tiburcio est\xE3o com fungos na cabe\xE7a! Corte
      3 delas e leve para o Tiburcio."
    m_Metadata:
      m_Items: []
  - m_Id: 226763587584
    m_Localized: Tiburcio I
